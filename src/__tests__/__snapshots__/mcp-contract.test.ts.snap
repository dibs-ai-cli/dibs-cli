            "type": "string",
          },
          "type": "array",
        },
        "title": {
          "description": "Short human-readable description of what you are working on",
          "type": "string",
        },
        "type": {
          "description": "FILE for specific path-scoped work; IDEA for broader efforts where paths are partially known",
          "enum": [
            "FILE",
            "IDEA",
